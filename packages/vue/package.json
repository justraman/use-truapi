{
  "name": "@use-truapi/vue",
  "version": "0.1.0",
  "description": "Vue composables for TrUAPI / Polkadot host products. One install: chain queries, accounts, transactions, chat, statements, payments, cloud storage.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/use-truapi/use-truapi.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "composables",
    "polkadot",
    "truapi",
    "product-sdk",
    "web3"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src"
  },
  "dependencies": {
    "@use-truapi/core": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "^5",
    "vue": ">=3.4"
  },
  "devDependencies": {
    "@tanstack/vue-query": "^5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "polkadot-api": "^2.1.6",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.17"
  }
}
